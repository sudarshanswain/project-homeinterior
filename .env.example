# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://homeinterior:homeinterior_secret@localhost:5432/homeinterior?schema=public
DIRECT_URL=postgresql://homeinterior:homeinterior_secret@localhost:5432/homeinterior?schema=public

# Auth — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@homeinterior.local
ADMIN_NOTIFICATION_EMAIL=admin@homeinterior.local

# Rate limiting
RATE_LIMIT_ENABLED=true
REDIS_URL=

# Public integrations
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Phone verification (future)
SMS_PROVIDER=
